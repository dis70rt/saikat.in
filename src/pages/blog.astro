---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
---

<Layout title="Blog — Saikat Das" description="Technical blog posts on Go, distributed systems, and backend engineering.">
  <Sidebar />

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card mt-4 lg:mt-0">
    <NavTabs />

    <div class="p-5 sm:p-6">
      <div class="tab-content-enter">
        <div id="blog-loading" class="flex flex-col gap-3">
          {[1, 2, 3].map(() => (
            <div class="border border-border rounded-sm bg-card p-4 animate-pulse">
              <div class="h-4 bg-muted rounded w-3/4 mb-2" />
              <div class="h-3 bg-muted rounded w-full mb-2" />
              <div class="h-3 bg-muted rounded w-1/2" />
            </div>
          ))}
        </div>
        <div id="blog-error" class="hidden text-center py-12">
          <p class="text-sm text-muted-foreground">Failed to load posts. Check back later.</p>
        </div>
        <div id="blog-empty" class="hidden text-center py-12">
          <p class="text-sm text-muted-foreground">No posts yet.</p>
        </div>
        <div id="blog-list" class="hidden flex-col gap-3"></div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { fetchHashnodePosts } from "../lib/hashnode";

  async function loadBlog() {
    const loading = document.getElementById("blog-loading");
    const error = document.getElementById("blog-error");
    const empty = document.getElementById("blog-empty");
    const list = document.getElementById("blog-list");

    // Only run if we are on the blog page
    if (!list) return;

    try {
      const posts = await fetchHashnodePosts();

      if (loading) loading.classList.add("hidden");

      if (posts.length === 0) {
        if (empty) empty.classList.remove("hidden");
        return;
      }

      list.style.display = "flex";
      list.innerHTML = posts.map(post => {
        const date = new Date(post.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
        const tags = (post.tags || []).slice(0, 3).map(t => t.name);
        return `
          <a href="${post.url}" target="_blank" rel="noopener noreferrer"
             class="border border-border rounded-sm bg-card p-4 hover:border-primary/40 transition-colors no-underline cursor-pointer block mb-3">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <p class="text-base font-medium text-foreground leading-snug">${post.title}</p>
                <p class="text-sm text-muted-foreground mt-1 leading-relaxed" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">${post.brief}</p>
              </div>
              <div class="flex flex-col items-end gap-1 flex-shrink-0 ml-2">
                <span class="text-xs text-muted-foreground whitespace-nowrap">${date}</span>
                <span class="text-xs text-muted-foreground">${post.readTimeInMinutes} min</span>
              </div>
            </div>
            ${tags.length > 0 ? `
              <div class="flex flex-wrap gap-1.5 mt-3">
                ${tags.map(t => `<span class="text-xs text-muted-foreground bg-muted/50 border border-border rounded-sm px-1.5 py-0.5">${t}</span>`).join("")}
              </div>
            ` : ""}
          </a>`;
      }).join("");
    } catch(_) {
      if (loading) loading.classList.add("hidden");
      if (error) error.classList.remove("hidden");
    }
  }

  // Run on initial load and every view transition
  document.addEventListener("astro:page-load", loadBlog);
</script>
