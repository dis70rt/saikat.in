---
import "../styles/global.css";
import { SIGNATURE_PATHS, SIGNATURE_VIEWBOX } from "@/data/signature-paths";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Saikat Das",
  description = "Backend engineer building fast, real-time systems in Go. IIT (BHU) Varanasi.",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/avatar.png", Astro.site);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Saikat Das" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Saikat Das" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:alt" content="Saikat Das portfolio" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/gsap.min.js"></script>
    <ClientRouter />
  </head>
  <body>
    <div id="loader" class="fixed inset-0 z-[9999] flex items-center justify-center bg-background" transition:persist>
      <div class="flex flex-col items-center gap-6 w-full max-w-sm px-8 select-none">
        <svg
          id="signature-svg"
          viewBox={SIGNATURE_VIEWBOX}
          class="w-full"
          aria-hidden="true"
          stroke="hsl(var(--primary))"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="transparent"
        >
          {SIGNATURE_PATHS.map((d) => (
            <path d={d} class="signature-path" />
          ))}
        </svg>
        <div class="w-32 h-px bg-border overflow-hidden rounded-full">
          <div id="loader-progress" class="h-full bg-primary rounded-full w-0"></div>
        </div>
      </div>
    </div>

    <div id="app-shell" class="min-h-screen bg-background text-foreground opacity-0">
      <main class="flex flex-col items-stretch min-h-screen p-2 sm:p-4 md:p-8">
        <div class="w-full max-w-6xl mx-auto">
          <div class="flex flex-col lg:flex-row gap-4 items-stretch lg:items-start">
            <slot />
          </div>
        </div>
      </main>
    </div>

    <style>
      .signature-path {
        opacity: 0;
      }
    </style>

    <script is:inline>
      function runLoader() {
        const loader = document.getElementById("loader");
        const shell = document.getElementById("app-shell");
        if (!loader || !shell) return;

        const seen = sessionStorage.getItem("loader-seen");
        if (seen) {
          loader.remove();
          shell.style.opacity = "1";
          return;
        }

        const paths = document.querySelectorAll(".signature-path");
        if (!paths.length || typeof gsap === "undefined") {
          loader.remove();
          shell.style.opacity = "1";
          return;
        }

        // Prepare all paths — measure real lengths
        paths.forEach(function(path) {
          var len = path.getTotalLength();
          path.style.strokeDasharray = len;
          path.style.strokeDashoffset = len;
          path.style.opacity = "1";
        });

        var stagger = 0.22;
        var duration = 0.4;
        var tl = gsap.timeline({
          onComplete: function() {
            gsap.to(loader, {
              opacity: 0,
              duration: 0.35,
              ease: "power2.inOut",
              onComplete: function() {
                loader.remove();
                sessionStorage.setItem("loader-seen", "1");
              }
            });
            gsap.to(shell, {
              opacity: 1,
              duration: 0.35,
              ease: "power2.inOut"
            });
          }
        });

        // Animate each path with natural pen-like easing
        paths.forEach(function(path, i) {
          tl.to(path, {
            strokeDashoffset: 0,
            duration: duration,
            ease: "power2.inOut"
          }, i * stagger);
        });

        // Progress bar tracks the full timeline
        var totalDuration = stagger * (paths.length - 1) + duration;
        var progress = document.getElementById("loader-progress");
        if (progress) {
          tl.to(progress, {
            width: "100%",
            duration: totalDuration,
            ease: "power1.inOut"
          }, 0);
        }

        // Small pause after drawing finishes before fading out
        tl.to({}, { duration: 0.3 });
      }

      // Run immediately
      runLoader();

      // Handle Astro view transitions
      document.addEventListener("astro:after-swap", function() {
        var loader = document.getElementById("loader");
        if (loader) loader.remove();
        var shell = document.getElementById("app-shell");
        if (shell) shell.style.opacity = "1";
      });

      // Maintain scroll position exactly where it is on tab clicks
      let scrollPos = 0;
      document.addEventListener("astro:before-preparation", () => {
        scrollPos = window.scrollY;
      });
      document.addEventListener("astro:after-swap", () => {
        window.scrollTo({ top: scrollPos, behavior: "instant" });
      });
    </script>
  </body>
</html>
