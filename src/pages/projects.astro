---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { projects } from "@/data/projects";

const sorted = [...projects].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<Layout title="Projects - Saikat Das" description="Open-source projects in Go, distributed systems, and real-time architectures.">
  <Sidebar />

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card mt-4 lg:mt-0 lg:max-h-[calc(100vh-4rem)] lg:flex lg:flex-col lg:sticky lg:top-8 lg:self-start">
    <NavTabs />

    <div class="p-5 sm:p-6 lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
      <div class="tab-content-enter lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
        {sorted.length === 0 ? (
          <div class="flex flex-col items-center gap-3 py-12 text-center">
            <p class="text-xs text-muted-foreground">
              No projects yet. Add them to <code class="text-primary">src/data/projects.ts</code>
            </p>
          </div>
        ) : (
          <div class="lg:flex-1 lg:overflow-y-auto lg:pr-2">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 items-start">
              {sorted.map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
