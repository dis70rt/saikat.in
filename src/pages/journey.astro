---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
import TimelineEntry from "@/components/TimelineEntry.astro";
import { journey, type JourneyKind } from "@/data/journey";

const kindConfig: Record<JourneyKind, { label: string; dot: string }> = {
  education:   { label: "Education",   dot: "bg-[var(--tn-blue)]" },
  internship:  { label: "Internship",  dot: "bg-[var(--tn-purple)]" },
  hackathon:   { label: "Hackathon",   dot: "bg-[var(--tn-yellow)]" },
  achievement: { label: "Achievement", dot: "bg-[var(--tn-green)]" },
  leadership:  { label: "Leadership",  dot: "bg-[var(--tn-cyan)]" },
};

const activeKinds = [...new Set(journey.map((e) => e.kind))];
---

<Layout title="Journey — Saikat Das" description="Education, hackathons, internships, and achievements timeline.">
  <Sidebar />

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card overflow-hidden mt-4 lg:mt-0">
    <NavTabs />

    <div class="p-5 sm:p-6">
      <div class="tab-content-enter">
        <div class="flex flex-wrap gap-x-4 gap-y-1.5 mb-6">
          {activeKinds.map((kind) => (
            <span class="flex items-center gap-1.5 text-xs text-muted-foreground">
              <span class={`w-2 h-2 rounded-full ${kindConfig[kind].dot}`} />
              {kindConfig[kind].label}
            </span>
          ))}
        </div>

        <div class="relative">
          <div class="absolute left-[7px] top-2 bottom-2 w-px bg-border" />
          <div class="flex flex-col gap-0">
            {journey.map((entry, idx) => (
              <TimelineEntry entry={entry} isLast={idx === journey.length - 1} />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
