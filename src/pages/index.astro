---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
import { projects } from "@/data/projects";
import { ExternalLink } from "lucide-react";

const latestProjects = projects.slice(0, 2);
---

<Layout title="Saikat Das — Backend Engineer" description="Backend engineer building fast, real-time systems in Go. IIT (BHU) Varanasi.">
  <Sidebar />

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card overflow-hidden mt-4 lg:mt-0">
    <NavTabs />

    <div class="p-5 sm:p-6">
      <div class="tab-content-enter flex flex-col gap-6">
        <section>
          <h2 class="text-sm text-primary uppercase tracking-widest mb-3 flex items-center gap-2">
            <span>►</span> About me
          </h2>
          <div class="border border-border rounded-sm bg-card p-4 sm:p-5">
            <p class="text-sm text-muted-foreground leading-relaxed">
              I build backend systems that stay fast under pressure. Most of my time goes into Go, real-time architectures, and databases. The rest goes into chess, sketching, strong coffee, and traveling to find great food.
            </p>
          </div>
        </section>

        <section id="latest-posts-section" class="hidden">
          <h2 class="text-sm text-primary uppercase tracking-widest mb-3 flex items-center gap-2">
            <span>≡</span> Latest Posts
          </h2>
          <div id="latest-posts-container" class="flex flex-col gap-2"></div>
        </section>

        {latestProjects.length > 0 && (
          <section>
            <h2 class="text-sm text-primary uppercase tracking-widest mb-3 flex items-center gap-2">
              <span>□</span> Latest Projects
            </h2>
            <div class="flex flex-col gap-2">
              {latestProjects.map((project) => (
                <a
                  href="/projects"
                  class="border border-border rounded-sm bg-card p-3 flex items-start justify-between gap-3 hover:border-primary/50 transition-colors no-underline cursor-pointer"
                >
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-foreground">{project.title}</p>
                    <p class="text-xs text-muted-foreground mt-0.5">{project.description}</p>
                  </div>
                  <span class="text-xs text-muted-foreground flex-shrink-0">
                    {new Date(project.date).toLocaleDateString("en-US", { month: "numeric", day: "numeric", year: "numeric" })}
                  </span>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </div>
</Layout>

<script>
  import { fetchHashnodePosts } from "../lib/hashnode";

  async function loadLatestPosts() {
    try {
      const posts = await fetchHashnodePosts();
      const latest = posts.slice(0, 2);
      if (latest.length === 0) return;

      const section = document.getElementById("latest-posts-section");
      const container = document.getElementById("latest-posts-container");
      if (!section || !container) return;

      section.classList.remove("hidden");
      container.innerHTML = latest.map((post) => `
        <a href="/blog" class="border border-border rounded-sm bg-card p-3 flex items-start justify-between gap-3 hover:border-primary/50 transition-colors no-underline cursor-pointer">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-foreground">${post.title}</p>
            <p class="text-xs text-muted-foreground mt-0.5 overflow-hidden text-ellipsis whitespace-nowrap">${post.brief}</p>
          </div>
          <span class="text-xs text-muted-foreground flex-shrink-0">
            ${new Date(post.publishedAt).toLocaleDateString("en-US", { month: "numeric", day: "numeric", year: "numeric" })}
          </span>
        </a>
      `).join("");
    } catch (_) {}
  }

  loadLatestPosts();
</script>
