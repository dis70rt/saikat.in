---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
import { fetchHashnodePosts } from "@/lib/hashnode";
import { Image } from "astro:assets";
import { localImages } from "@/lib/images";

const posts = fetchHashnodePosts();
---

<Layout title="Blog - Saikat Das" description="Technical blog posts on Go, distributed systems, and backend engineering.">
  <Sidebar />

  <div class="flex-1 min-w-0 nb-card mt-4 lg:mt-0 lg:max-h-[calc(100vh-4rem)] lg:flex lg:flex-col lg:sticky lg:top-8 lg:self-start">
    <NavTabs />

    <div class="p-5 sm:p-6 lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
      <div class="tab-content-enter lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
        {posts.length === 0 ? (
          <div class="text-center py-12">
            <p class="text-sm text-muted-foreground font-bold uppercase tracking-widest">No posts yet.</p>
          </div>
        ) : (
          <div class="lg:flex-1 lg:overflow-y-auto p-2 -m-2">
            <div class="flex flex-col gap-3">
              {posts.map((post) => {
                const date = new Date(post.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
                const tags = (post.tags || []).slice(0, 3);
                return (
                  <a
                    href={post.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="nb-shadow border-2 border-[hsl(var(--border))] bg-card p-4 transition-all duration-100 no-underline cursor-pointer flex flex-row items-start gap-4 group hover:bg-muted/20 hover:-translate-y-[2px] hover:-translate-x-[2px] hover:shadow-[5px_5px_0_0_#000]"
                  >
                    {post.coverImage && (
                      <div class="w-20 h-20 sm:w-28 sm:h-28 flex-shrink-0 border-2 border-[hsl(var(--border))] overflow-hidden bg-muted/20 aspect-square skeleton-bg">
                        {post.coverImage.startsWith('http') ? (
                          <Image src={post.coverImage} alt={post.title} inferSize={true} class="w-full h-full object-cover fade-in-image" />
                        ) : localImages[`/src/assets${post.coverImage}`] ? (
                          <Image src={localImages[`/src/assets${post.coverImage}`]()} alt={post.title} class="w-full h-full object-cover fade-in-image" />
                        ) : null}
                      </div>
                    )}
                    <div class="flex-1 min-w-0 w-full">
                      <div class="flex items-start justify-between gap-3">
                      <div class="flex-1 min-w-0">
                        <p class="text-base font-bold text-foreground leading-snug tracking-tight">{post.title}</p>
                        <p class="text-sm text-muted-foreground mt-1 leading-relaxed line-clamp-2">{post.brief}</p>
                      </div>
                      <div class="hidden sm:flex flex-col items-end gap-1 flex-shrink-0 ml-2">
                        <span class="text-xs text-muted-foreground whitespace-nowrap font-mono">{date}</span>
                        <span class="text-xs text-muted-foreground font-mono">{post.readTimeInMinutes} min</span>
                      </div>
                    </div>
                    {tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mt-3">
                        {tags.map((t) => (
                          <span class="nb-tag text-muted-foreground border-border bg-muted/40 px-1.5 py-0.5">{t.name}</span>
                        ))}
                      </div>
                    )}
                    <div class="flex sm:hidden items-center gap-2 mt-2 text-xs text-muted-foreground font-mono">
                      <span>{date}</span>
                      <span>·</span>
                      <span>{post.readTimeInMinutes} min read</span>
                    </div>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
