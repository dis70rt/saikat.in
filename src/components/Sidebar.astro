---
import { profile } from "@/data/profile";
import { journey } from "@/data/journey";
import { Github, Linkedin, Mail, MapPin, User, FileText, Code, Phone, type LucideIcon } from "lucide-react";

const highlights = journey.filter((e) => e.kind === "hackathon" || e.kind === "achievement");
const doubled = [...highlights, ...highlights];

const iconMap: Record<string, LucideIcon> = {
  github: Github,
  linkedin: Linkedin,
  mail: Mail,
  code: Code,
};

const categoryColor: Record<string, string> = {
  language:  "text-[var(--tn-blue)] border-[var(--tn-blue)]/20 bg-[var(--tn-blue)]/5",
  framework: "text-[var(--tn-purple)] border-[var(--tn-purple)]/20 bg-[var(--tn-purple)]/5",
  infra:     "text-[var(--tn-yellow)] border-[var(--tn-yellow)]/20 bg-[var(--tn-yellow)]/5",
  database:  "text-[var(--tn-green)] border-[var(--tn-green)]/20 bg-[var(--tn-green)]/5",
};

const highlightColor = (kind: string) =>
  kind === "hackathon" ? "text-[var(--tn-yellow)]" : "text-[var(--tn-green)]";
---

<aside transition:persist="sidebar" class="w-full lg:w-72 flex-shrink-0 flex flex-col gap-4 lg:sticky lg:top-8 lg:self-start lg:max-h-[calc(100vh-4rem)] lg:overflow-y-auto">
  <div class="border border-border rounded-sm bg-card p-4 sm:p-5 flex flex-col gap-4">
    <div class="flex items-center gap-3 flex-wrap">
      <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-sm border border-border bg-muted flex items-center justify-center flex-shrink-0 overflow-hidden">
        {profile.avatar ? (
          <img src={profile.avatar} alt={profile.name} class="w-full h-full object-cover rounded-sm" loading="lazy" />
        ) : (
          <User size={24} className="text-muted-foreground" />
        )}
      </div>
      <div>
        <h1 class="text-base font-semibold text-foreground">{profile.name}</h1>
        <p class="text-xs text-primary mt-0.5">{profile.title}</p>
      </div>
    </div>

    <div class="flex items-center gap-1.5 text-sm text-muted-foreground mt-2">
      <MapPin size={11} />
      <span>{profile.location}</span>
    </div>

    <p class="text-sm text-muted-foreground leading-relaxed mt-2">{profile.bio}</p>
  </div>

  <div class="border border-border rounded-sm bg-card px-4 py-3 flex flex-col gap-2">
    <div class="flex items-center gap-2">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
      </span>
      <span class="text-xs font-medium text-foreground">Open to work</span>
    </div>
    <div class="flex items-center gap-2 text-xs text-muted-foreground">
      <Mail size={12} />
      <a href={`mailto:${profile.email}`} class="hover:text-foreground transition-colors">{profile.email}</a>
    </div>
    <div class="flex items-center gap-2 text-xs text-muted-foreground">
      <Phone size={12} />
      <a href={`tel:${profile.phone.replace(/\s/g, '')}`} class="hover:text-foreground transition-colors">{profile.phone}</a>
    </div>
  </div>

  {profile.techStack.length > 0 && (
    <div class="border border-border rounded-sm bg-card p-3 sm:p-4 flex flex-col gap-3">
      <p class="text-xs text-muted-foreground uppercase tracking-widest">Tech Stack</p>
      <div class="flex flex-wrap gap-1.5">
        {profile.techStack.map((tech) => (
          <span class={`text-xs border rounded-sm px-2 py-0.5 ${categoryColor[tech.category] ?? "text-muted-foreground border-border bg-muted/30"}`}>
            {tech.name}
          </span>
        ))}
      </div>
      <div class="flex flex-wrap gap-x-2 gap-y-1 mt-0.5">
        {(["language", "framework", "infra", "database"] as const).map((cat) => {
          const hasAny = profile.techStack.some((t) => t.category === cat);
          if (!hasAny) return null;
          return (
            <span class={`flex items-center gap-1 text-[9px] rounded-lg px-1.5 py-0.5 ${categoryColor[cat]}`}>
              <span class="w-1.5 h-1.5 rounded-full inline-block" style={{ borderColor: "currentColor", background: "currentColor", opacity: 0.5 }} />
              {cat}
            </span>
          );
        })}
      </div>
    </div>
  )}

  {highlights.length > 0 && (
    <div class="border border-border rounded-sm bg-card py-3 overflow-hidden">
      <p class="text-xs text-muted-foreground uppercase tracking-widest px-4 mb-2">Highlights</p>
      <div class="marquee-container">
        <div class="marquee-track">
          {doubled.map((entry) => (
            <a
              href="/journey"
              class="inline-flex items-center gap-2 px-3 py-2 mr-3 rounded-sm border border-border bg-muted/30 hover:bg-muted/60 transition-colors no-underline cursor-pointer flex-shrink-0 whitespace-nowrap"
            >
              <span class={`text-[10px] font-semibold ${highlightColor(entry.kind)}`}>
                {entry.highlight ?? entry.kind}
              </span>
              <span class="text-[10px] text-muted-foreground">-</span>
              <span class="text-xs text-foreground">{entry.org}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  {profile.interests.length > 0 && (
    <div class="rounded-sm bg-muted/30 p-4 flex flex-col gap-3">
      <p class="text-xs text-muted-foreground uppercase tracking-widest">Interests</p>
      <div class="flex flex-col gap-1.5">
        {profile.interests.map((interest) => (
          <div class="flex items-center gap-2 text-xs text-muted-foreground">
            <span class="text-primary text-[9px]">&#x25B8;</span>
            {interest}
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="border border-border rounded-sm bg-card p-4 flex flex-col gap-3">
    <p class="text-xs text-muted-foreground uppercase tracking-widest">Socials</p>
    <div class="flex gap-2 flex-wrap">
      {profile.socials.map((s) => {
        const Icon = iconMap[s.icon] || Mail;
        return (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            title={s.label}
            class="w-9 h-9 border border-border rounded-sm bg-muted/40 flex items-center justify-center text-muted-foreground hover:text-foreground hover:border-primary/50 transition-colors cursor-pointer"
          >
            <Icon size={15} />
          </a>
        );
      })}
    </div>

    {profile.resumeUrl ? (
      <a
        href={profile.resumeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 text-sm border border-primary/40 text-primary rounded-sm py-1.5 px-3 hover:bg-primary/10 transition-colors cursor-pointer"
      >
        <FileText size={12} />
        View Resume
      </a>
    ) : (
      <div
        title="Resume not available"
        class="flex items-center justify-center gap-2 text-xs border border-border text-muted-foreground/40 rounded-sm py-1.5 px-3 cursor-not-allowed select-none"
      >
        <FileText size={12} />
        View Resume
      </div>
    )}
  </div>
</aside>
