---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
import { projects } from "@/data/projects";
import { journey } from "@/data/journey";
import { fetchHashnodePosts } from "@/lib/hashnode";
import { badgeStyle } from "@/data/colors";
import { Image } from "astro:assets";

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpeg,jpg,png,gif,webp,svg}');

const HOME_PREVIEW_COUNT = 2;
const latestProjects = projects.slice(0, HOME_PREVIEW_COUNT);
const experience = journey.filter((e) => e.kind === "internship");
const education = journey.find((e) => e.kind === "education");
const latestPosts = fetchHashnodePosts().slice(0, HOME_PREVIEW_COUNT);
---

<Layout title="Saikat Das - Backend Engineer" description="Backend engineer building fast, real-time systems in Go. IIT (BHU) Varanasi.">
  <Sidebar />

  <div class="flex-1 min-w-0 nb-card mt-4 lg:mt-0 lg:max-h-[calc(100vh-4rem)] lg:flex lg:flex-col lg:sticky lg:top-8 lg:self-start">
    <NavTabs />

    <div class="p-5 sm:p-6 lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
      <div class="tab-content-enter lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
        <div class="lg:flex-1 lg:overflow-y-auto p-2 -m-2 flex flex-col gap-7">

          <!-- About -->
          <section>
            <h2 class="nb-section-label mb-3">About me</h2>
            <div>
              <p class="text-base text-muted-foreground leading-relaxed">
                I build backend systems that stay fast under pressure. Most of my time goes into Go, real-time architectures, and databases. The rest goes into chess, sketching, strong coffee, and traveling to find great food.
              </p>
            </div>
          </section>

          <!-- Experience -->
          {experience.length > 0 && (
            <section>
              <h2 class="nb-section-label mb-3">Experience</h2>
              <div class="flex flex-col gap-2">
                {experience.map((entry) => (
                  <a
                    href="/journey"
                    class="bg-muted/15 border-2 border-[hsl(var(--border))] p-3 flex items-start justify-between gap-3 transition-all duration-100 no-underline cursor-pointer group hover:bg-muted/40 hover:-translate-y-[2px] hover:-translate-x-[2px] hover:shadow-[4px_4px_0_0_#000]"
                    style="box-shadow: 2px 2px 0 0 #000;"
                  >
                    {entry.logo && (
                      <div class={`w-10 h-10 flex-shrink-0 overflow-hidden skeleton-bg ${entry.logoPadding ? 'bg-white p-1' : ''}`}>
                        {entry.logo.startsWith('http') ? (
                          <Image src={entry.logo} alt={entry.org} inferSize={true} class="w-full h-full object-contain fade-in-image" />
                        ) : images[`/src/assets${entry.logo}`] ? (
                          <Image src={images[`/src/assets${entry.logo}`]()} alt={entry.org} class="w-full h-full object-contain fade-in-image" />
                        ) : null}
                      </div>
                    )}
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-bold text-foreground leading-snug tracking-tight">{entry.title}</p>
                      <p class="text-xs text-muted-foreground mt-0.5 font-medium">{entry.org} · {entry.period}</p>
                      {entry.bullets && entry.bullets.length > 0 ? (
                        <ul class="mt-1.5 flex flex-col gap-1">
                          {entry.bullets.map((point) => (
                            <li class="text-xs text-muted-foreground flex items-start gap-1.5">
                              <span class="text-[var(--tn-blue)] font-bold text-[8px] mt-[3px] flex-shrink-0">→</span>
                              <span>{point}</span>
                            </li>
                          ))}
                        </ul>
                      ) : entry.description && (
                        <p class="text-xs text-muted-foreground mt-1.5">{entry.description}</p>
                      )}
                    </div>
                    {entry.highlight && (
                      <span
                        class="hidden sm:inline-block text-[10px] border-2 px-1.5 py-0.5 flex-shrink-0 font-black uppercase tracking-wider"
                        style={badgeStyle(entry.kind)}
                      >
                        {entry.highlight}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </section>
          )}

          <!-- Education -->
          {education && (
            <section>
              <h2 class="nb-section-label mb-3">Education</h2>
              <div>
                <a
                  href="/journey"
                  class="bg-muted/15 border-2 border-[hsl(var(--border))] p-3 flex items-start justify-between gap-3 transition-all duration-100 no-underline cursor-pointer hover:bg-muted/40 hover:-translate-y-[2px] hover:-translate-x-[2px] hover:shadow-[4px_4px_0_0_#000]"
                  style="box-shadow: 2px 2px 0 0 #000;"
                >
                  {education.logo && (
                    <div class="w-10 h-10 flex-shrink-0 overflow-hidden skeleton-bg">
                      {education.logo.startsWith('http') ? (
                        <Image src={education.logo} alt={education.org} inferSize={true} class="w-full h-full object-contain fade-in-image" />
                      ) : images[`/src/assets${education.logo}`] ? (
                        <Image src={images[`/src/assets${education.logo}`]()} alt={education.org} class="w-full h-full object-contain fade-in-image" />
                      ) : null}
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-foreground leading-snug tracking-tight">{education.title}</p>
                    <p class="text-xs text-muted-foreground mt-0.5 font-medium">{education.org} · {education.period}</p>
                  </div>
                  <span
                    class="hidden sm:inline-block text-[10px] border-2 px-1.5 py-0.5 flex-shrink-0 font-black uppercase tracking-wider"
                    style={badgeStyle("education")}
                  >
                    Education
                  </span>
                </a>
              </div>
            </section>
          )}

          <!-- Latest Projects -->
          {latestProjects.length > 0 && (
            <section>
              <h2 class="nb-section-label mb-3">Latest Projects</h2>
              <div class="flex flex-col gap-2">
                {latestProjects.map((project) => (
                  <a
                    href="/projects"
                    class="bg-muted/15 border-2 border-[hsl(var(--border))] p-3 flex items-start justify-between gap-3 transition-all duration-100 no-underline cursor-pointer hover:bg-muted/40 hover:-translate-y-[2px] hover:-translate-x-[2px] hover:shadow-[4px_4px_0_0_#000]"
                    style="box-shadow: 2px 2px 0 0 #000;"
                  >
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-bold text-foreground tracking-tight">{project.title}</p>
                      <p class="text-xs text-muted-foreground mt-0.5 line-clamp-1">{project.description}</p>
                    </div>
                    <span class="hidden sm:inline-block text-xs text-muted-foreground flex-shrink-0 font-mono">
                      {(() => { const d = new Date(project.date); return isNaN(d.getTime()) ? '' : d.toLocaleDateString("en-US", { month: "short", year: "numeric" }); })()}
                    </span>
                  </a>
                ))}
              </div>
            </section>
          )}

          <!-- Latest Posts -->
          {latestPosts.length > 0 && (
            <section>
              <h2 class="nb-section-label mb-3">Latest Posts</h2>
              <div class="flex flex-col gap-2">
                {latestPosts.map((post) => {
                  const date = new Date(post.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
                  return (
                    <a
                      href={post.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="bg-muted/15 border-2 border-[hsl(var(--border))] p-3 flex items-start justify-between gap-3 transition-all duration-100 no-underline cursor-pointer hover:bg-muted/40 hover:-translate-y-[2px] hover:-translate-x-[2px] hover:shadow-[4px_4px_0_0_#000]"
                      style="box-shadow: 2px 2px 0 0 #000;"
                    >
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-foreground tracking-tight">{post.title}</p>
                        <p class="text-xs text-muted-foreground mt-0.5 line-clamp-1">{post.brief}</p>
                      </div>
                      <div class="hidden sm:flex flex-col items-end gap-0.5 flex-shrink-0">
                        <span class="text-xs text-muted-foreground font-mono">{date}</span>
                        <span class="text-[11px] text-muted-foreground font-mono">{post.readTimeInMinutes}m</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </section>
          )}

        </div>
      </div>
    </div>
  </div>
</Layout>
