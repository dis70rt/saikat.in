---
import type { JourneyEntry, JourneyKind } from "@/data/journey";

interface Props {
  entry: JourneyEntry;
  isLast?: boolean;
}

const { entry, isLast = false } = Astro.props;

const kindConfig: Record<JourneyKind, { label: string; dot: string; badge: string }> = {
  education:   { label: "Education",   dot: "bg-[var(--tn-blue)]",   badge: "text-[var(--tn-blue)] border-[var(--tn-blue)]/25 bg-[var(--tn-blue)]/5" },
  internship:  { label: "Internship",  dot: "bg-[var(--tn-purple)]", badge: "text-[var(--tn-purple)] border-[var(--tn-purple)]/25 bg-[var(--tn-purple)]/5" },
  hackathon:   { label: "Hackathon",   dot: "bg-[var(--tn-yellow)]", badge: "text-[var(--tn-yellow)] border-[var(--tn-yellow)]/25 bg-[var(--tn-yellow)]/5" },
  achievement: { label: "Achievement", dot: "bg-[var(--tn-green)]",  badge: "text-[var(--tn-green)] border-[var(--tn-green)]/25 bg-[var(--tn-green)]/5" },
  leadership:  { label: "Leadership",  dot: "bg-[var(--tn-cyan)]",   badge: "text-[var(--tn-cyan)] border-[var(--tn-cyan)]/25 bg-[var(--tn-cyan)]/5" },
};

const cfg = kindConfig[entry.kind];
---

<div class={`relative flex gap-4 ${isLast ? "pb-0" : "pb-6"}`}>
  <div class="relative z-10 flex-shrink-0 mt-1">
    <span class={`block w-3.5 h-3.5 rounded-full border-2 border-background ${cfg.dot}`} />
  </div>

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card p-4 flex flex-col gap-2 hover:border-primary/30 transition-colors">
    <div class="flex items-start justify-between gap-3 flex-wrap">
      <div>
        <div class="flex items-center gap-2 flex-wrap">
          <h3 class="text-sm font-semibold text-foreground">{entry.title}</h3>
          {entry.highlight && (
            <span class={`text-[10px] border rounded-sm px-1.5 py-0.5 font-medium ${cfg.badge}`}>
              {entry.highlight}
            </span>
          )}
        </div>
        <p class="text-xs text-muted-foreground mt-0.5">
          {entry.org} &middot; {entry.period}
        </p>
      </div>
      <span class={`text-[10px] border rounded-sm px-1.5 py-0.5 flex-shrink-0 ${cfg.badge}`}>
        {cfg.label}
      </span>
    </div>

    {entry.description && (
      <p class="text-sm text-muted-foreground leading-relaxed">{entry.description}</p>
    )}

    {entry.tags && entry.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-1">
        {entry.tags.map((tag) => (
          <span class="text-xs text-muted-foreground bg-muted/50 border border-border rounded-sm px-1.5 py-0.5">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
