---
import type { JourneyEntry, JourneyKind } from "@/data/journey";

interface Props {
  entry: JourneyEntry;
  isLast?: boolean;
}

const { entry, isLast = false } = Astro.props;

const kindConfig: Record<JourneyKind, { label: string; dotColor: string; textColor: string; borderColor: string; bgColor: string }> = {
  education:   { label: "Education",   dotColor: "#7aa2f7", textColor: "#7aa2f7", borderColor: "rgba(122,162,247,0.25)", bgColor: "rgba(122,162,247,0.07)" },
  internship:  { label: "Internship",  dotColor: "#bb9af7", textColor: "#bb9af7", borderColor: "rgba(187,154,247,0.25)", bgColor: "rgba(187,154,247,0.07)" },
  hackathon:   { label: "Hackathon",   dotColor: "#e0af68", textColor: "#e0af68", borderColor: "rgba(224,175,104,0.25)", bgColor: "rgba(224,175,104,0.07)" },
  achievement: { label: "Achievement", dotColor: "#9ece6a", textColor: "#9ece6a", borderColor: "rgba(158,206,106,0.25)", bgColor: "rgba(158,206,106,0.07)" },
  leadership:  { label: "Leadership",  dotColor: "#7dcfff", textColor: "#7dcfff", borderColor: "rgba(125,207,255,0.25)", bgColor: "rgba(125,207,255,0.07)" },
};

const cfg = kindConfig[entry.kind];
const badgeStyle = `color:${cfg.textColor};border-color:${cfg.borderColor};background:${cfg.bgColor}`;
---

<div class={`relative flex gap-4 ${isLast ? "pb-0" : "pb-6"}`}>
  {!isLast && (
    <div class="absolute left-[5px] top-[12px] -bottom-[12px] w-[2px] bg-border" />
  )}
  <div class="relative z-10 flex-shrink-0 mt-1.5">
    <span class="block w-3 h-3 rounded-full border-2 border-card" style={`background:${cfg.dotColor}`} />
  </div>

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card p-4 flex flex-col gap-2 hover:border-primary/30 transition-colors">
    <div class="flex items-start justify-between gap-3 flex-wrap">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 flex-wrap">
          <h3 class="text-sm font-semibold text-foreground leading-snug">{entry.title}</h3>
          {entry.highlight && (
            <span class="text-[11px] border rounded-sm px-1.5 py-0.5 font-medium flex-shrink-0" style={badgeStyle}>
              {entry.highlight}
            </span>
          )}
        </div>
        <p class="text-xs text-muted-foreground mt-0.5">
          {entry.org} &middot; {entry.period}
        </p>
      </div>
      <span class="text-[11px] border rounded-sm px-1.5 py-0.5 flex-shrink-0 font-medium" style={badgeStyle}>
        {cfg.label}
      </span>
    </div>

    {entry.description && (
      <p class="text-sm text-muted-foreground leading-relaxed">{entry.description}</p>
    )}

    {entry.tags && entry.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-1">
        {entry.tags.map((tag) => (
          <span class="text-xs text-muted-foreground bg-muted/50 border border-border rounded-sm px-1.5 py-0.5">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
