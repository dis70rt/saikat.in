---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
import { fetchHashnodePosts } from "@/lib/hashnode";

const posts = fetchHashnodePosts();
---

<Layout title="Blog - Saikat Das" description="Technical blog posts on Go, distributed systems, and backend engineering.">
  <Sidebar />

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card mt-4 lg:mt-0">
    <NavTabs />

    <div class="p-5 sm:p-6">
      <div class="tab-content-enter">
        {posts.length === 0 ? (
          <div class="text-center py-12">
            <p class="text-sm text-muted-foreground">No posts yet.</p>
          </div>
        ) : (
          <div class="lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto lg:pr-2">
            <div class="flex flex-col gap-3">
              {posts.map((post) => {
                const date = new Date(post.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
                const tags = (post.tags || []).slice(0, 3);
                return (
                  <a
                    href={post.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="border border-border rounded-sm bg-card p-4 hover:border-primary/40 transition-colors no-underline cursor-pointer block"
                  >
                    <div class="flex items-start justify-between gap-3">
                      <div class="flex-1 min-w-0">
                        <p class="text-base font-medium text-foreground leading-snug">{post.title}</p>
                        <p class="text-sm text-muted-foreground mt-1 leading-relaxed line-clamp-2">{post.brief}</p>
                      </div>
                      <div class="hidden sm:flex flex-col items-end gap-1 flex-shrink-0 ml-2">
                        <span class="text-xs text-muted-foreground whitespace-nowrap">{date}</span>
                        <span class="text-xs text-muted-foreground">{post.readTimeInMinutes} min</span>
                      </div>
                    </div>
                    {tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mt-3">
                        {tags.map((t) => (
                          <span class="text-xs text-muted-foreground bg-muted/50 border border-border rounded-sm px-1.5 py-0.5">{t.name}</span>
                        ))}
                      </div>
                    )}
                    <div class="flex sm:hidden items-center gap-2 mt-2 text-xs text-muted-foreground">
                      <span>{date}</span>
                      <span>·</span>
                      <span>{post.readTimeInMinutes} min read</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
