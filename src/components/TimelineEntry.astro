---
import type { JourneyEntry, JourneyKind } from "@/data/journey";
import { kindColors, badgeStyle } from "@/data/colors";

interface Props {
  entry: JourneyEntry;
  isLast?: boolean;
}

const { entry, isLast = false } = Astro.props;

const kindLabels: Record<JourneyKind, string> = {
  education: "Education",
  internship: "Internship",
  hackathon: "Hackathon",
  achievement: "Achievement",
  leadership: "Leadership",
};

const label = kindLabels[entry.kind];
const dotColor = kindColors[entry.kind].hex;
---

<div class={`relative flex gap-4 ${isLast ? "pb-0" : "pb-6"}`}>
  {!isLast && (
    <div class="absolute left-[5px] top-[12px] -bottom-[12px] w-[2px] bg-border" />
  )}
  <div class="relative z-10 flex-shrink-0 mt-1.5">
    <span class="block w-3 h-3 rounded-full border-2 border-card" style={`background:${dotColor}`} />
  </div>

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card p-4 flex flex-col gap-2 hover:border-primary/30 transition-colors">
    <div class="flex items-start justify-between gap-3 flex-wrap">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 flex-wrap">
          <h3 class="text-sm font-semibold text-foreground leading-snug">{entry.title}</h3>
          {entry.highlight && (
            <span class="text-[11px] border rounded-sm px-1.5 py-0.5 font-medium flex-shrink-0" style={badgeStyle(entry.kind)}>
              {entry.highlight}
            </span>
          )}
        </div>
        <p class="text-xs text-muted-foreground mt-0.5">
          {entry.org} &middot; {entry.period}
        </p>
      </div>
      <span class="text-[11px] border rounded-sm px-1.5 py-0.5 flex-shrink-0 font-medium" style={badgeStyle(entry.kind)}>
        {label}
      </span>
    </div>

    {entry.description && (
      <p class="text-sm text-muted-foreground leading-relaxed">{entry.description}</p>
    )}

    {entry.tags && entry.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-1">
        {entry.tags.map((tag) => (
          <span class="text-xs text-muted-foreground bg-muted/50 border border-border rounded-sm px-1.5 py-0.5">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
