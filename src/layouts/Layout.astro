---
import "../styles/global.css";
import { SIGNATURE_PATHS, SIGNATURE_VIEWBOX, LETTER_DURATION, LETTER_STAGGER } from "@/data/signature-paths";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Saikat Das",
  description = "Backend engineer building fast, real-time systems in Go. IIT (BHU) Varanasi.",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/avatar.png", Astro.site);
const drawDuration = LETTER_STAGGER * (SIGNATURE_PATHS.length - 1) + LETTER_DURATION;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Saikat Das" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Saikat Das" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:alt" content="Saikat Das portfolio" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body>
    <div id="loader" class="fixed inset-0 z-[9999] flex items-center justify-center bg-background" transition:persist>
      <div class="flex flex-col items-center gap-6 w-full max-w-sm px-8 select-none">
        <svg
          viewBox={SIGNATURE_VIEWBOX}
          class="w-full"
          aria-hidden="true"
          stroke="hsl(var(--primary))"
          stroke-width="2"
          stroke-linecap="round"
          fill="transparent"
        >
          {SIGNATURE_PATHS.map((d, i) => {
            const delay = i * LETTER_STAGGER;
            return (
              <path
                d={d}
                class="signature-path"
                style={`--path-delay: ${delay}s; --path-duration: ${LETTER_DURATION}s`}
              />
            );
          })}
        </svg>
        <div class="w-32 h-px bg-border overflow-hidden rounded-full">
          <div class="h-full bg-primary rounded-full" style={`animation: progressBar ${drawDuration}s linear forwards`}></div>
        </div>
      </div>
    </div>

    <div id="app-shell" class="min-h-screen bg-background text-foreground opacity-0 transition-opacity duration-300">
      <main class="flex flex-col items-stretch min-h-screen p-2 sm:p-4 md:p-8">
        <div class="w-full max-w-6xl mx-auto">
          <div class="flex flex-col lg:flex-row gap-4 items-stretch lg:items-start">
            <slot />
          </div>
        </div>
      </main>
    </div>

    <style>
      .signature-path {
        stroke-dasharray: 2000;
        stroke-dashoffset: 2000;
        opacity: 0;
        animation:
          showPath 0.001s var(--path-delay) forwards,
          drawPath var(--path-duration) var(--path-delay) linear forwards;
      }
      @keyframes showPath {
        to { opacity: 1; }
      }
      @keyframes drawPath {
        to { stroke-dashoffset: 0; }
      }
      @keyframes progressBar {
        from { width: 0%; }
        to { width: 100%; }
      }
    </style>

    <script>
      function runLoader() {
        const loader = document.getElementById("loader");
        const shell = document.getElementById("app-shell");
        if (!loader || !shell) return;

        const seen = sessionStorage.getItem("loader-seen");
        if (seen) {
          loader.remove();
          shell.style.opacity = "1";
          return;
        }

        const totalMs = (0.24 * 8 + 0.36) * 1000 + 1000;
        setTimeout(() => {
          loader.style.transition = "opacity 0.25s ease-out";
          loader.style.opacity = "0";
          shell.style.opacity = "1";
          setTimeout(() => {
            loader.remove();
            sessionStorage.setItem("loader-seen", "1");
          }, 250);
        }, totalMs);
      }
      runLoader();

      document.addEventListener("astro:after-swap", () => {
        const loader = document.getElementById("loader");
        if (loader) loader.remove();
        const shell = document.getElementById("app-shell");
        if (shell) shell.style.opacity = "1";
      });
    </script>
  </body>
</html>
