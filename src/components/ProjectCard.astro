---
import { ExternalLink, Tag } from "lucide-react";
import type { Project } from "@/data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const linkStyle: Record<string, string> = {
  "Frontend":    "border-[var(--tn-blue)]/40 text-[var(--tn-blue)] hover:bg-[var(--tn-blue)]/10",
  "Backend":     "border-[var(--tn-green)]/40 text-[var(--tn-green)] hover:bg-[var(--tn-green)]/10",
  "Open Source": "border-[var(--tn-purple)]/40 text-[var(--tn-purple)] hover:bg-[var(--tn-purple)]/10",
  "Open Project":"border-primary/40 text-primary hover:bg-primary/10",
  "Paper":       "border-[var(--tn-yellow)]/40 text-[var(--tn-yellow)] hover:bg-[var(--tn-yellow)]/10",
  "Video":       "border-[var(--tn-orange)]/40 text-[var(--tn-orange)] hover:bg-[var(--tn-orange)]/10",
  "Play Store":  "border-[var(--tn-green)]/40 text-[var(--tn-green)] hover:bg-[var(--tn-green)]/10",
};

const defaultStyle = "border-border text-muted-foreground hover:text-foreground hover:border-primary/50";

const activeLinks = (project.links ?? []).filter((l) => l.url.trim() !== "").slice(0, 4);
---

<div class="border border-border rounded-sm bg-card p-5 flex flex-col gap-4 hover:border-primary/40 transition-colors group">
  <div class="flex items-start justify-between gap-2">
    <h3 class="text-base font-semibold text-foreground leading-snug">{project.title}</h3>
    {project.featured && (
      <span class="text-[10px] text-primary border border-primary/30 rounded-sm px-1.5 py-0.5 flex-shrink-0">
        featured
      </span>
    )}
  </div>

  <div class="flex-1 flex flex-col gap-2">
    {project.description && (
      <p class="text-sm text-muted-foreground leading-relaxed">{project.description}</p>
    )}

    {project.bullets && project.bullets.length > 0 && (
      <details class="group/details">
        <summary class="text-xs text-primary cursor-pointer hover:text-primary/80 transition-colors list-none flex items-center gap-1">
          <span class="group-open/details:rotate-90 transition-transform text-[10px]">▶</span>
          details
        </summary>
        <ul class="list-disc list-inside text-sm text-muted-foreground leading-relaxed max-w-full space-y-1.5 ml-3 mt-2">
          {project.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
      </details>
    )}
  </div>

  {project.tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {project.tags.map((tag) => (
        <span class="flex items-center gap-1 text-xs text-muted-foreground bg-muted/60 px-1.5 py-0.5 rounded-sm">
          <Tag size={8} />
          {tag}
        </span>
      ))}
    </div>
  )}

  {activeLinks.length > 0 && (
    <div class="flex flex-wrap gap-2 pt-1 border-t border-border">
      {activeLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class={`flex items-center gap-1.5 text-xs border rounded-sm px-2.5 py-1.5 transition-colors whitespace-nowrap cursor-pointer ${
            linkStyle[link.label] ?? defaultStyle
          }`}
        >
          <ExternalLink size={10} className="flex-shrink-0" />
          {link.label}
        </a>
      ))}
    </div>
  )}
</div>
