---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
---

<Layout title="Blog — Saikat Das" description="Technical blog posts on Go, distributed systems, and backend engineering.">
  <Sidebar />

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card overflow-hidden mt-4 lg:mt-0">
    <NavTabs />

    <div class="p-5 sm:p-6">
      <div class="tab-content-enter">
        <div id="blog-loading" class="flex flex-col gap-3">
          {[1, 2, 3].map(() => (
            <div class="border border-border rounded-sm bg-card p-4 animate-pulse">
              <div class="h-4 bg-muted rounded w-3/4 mb-2" />
              <div class="h-3 bg-muted rounded w-full mb-2" />
              <div class="h-3 bg-muted rounded w-1/2" />
            </div>
          ))}
        </div>

        <div id="blog-error" class="hidden text-center py-12">
          <p class="text-sm text-muted-foreground">Failed to load posts. Check back later.</p>
        </div>

        <div id="blog-empty" class="hidden text-center py-12">
          <p class="text-sm text-muted-foreground">No posts yet.</p>
        </div>

        <div id="blog-list" class="hidden flex flex-col gap-3"></div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { fetchHashnodePosts } from "../lib/hashnode";

  async function loadBlog() {
    const loading = document.getElementById("blog-loading");
    const error = document.getElementById("blog-error");
    const empty = document.getElementById("blog-empty");
    const list = document.getElementById("blog-list");

    try {
      const posts = await fetchHashnodePosts();

      loading?.classList.add("hidden");

      if (posts.length === 0) {
        empty?.classList.remove("hidden");
        return;
      }

      if (!list) return;
      list.classList.remove("hidden");
      list.innerHTML = posts.map((post) => {
        const date = new Date(post.publishedAt).toLocaleDateString("en-US", {
          month: "short", day: "numeric", year: "numeric"
        });
        const tags = post.tags.map((t) => t.name).slice(0, 3);

        return `
          <a href="${post.url}" target="_blank" rel="noopener noreferrer"
             class="border border-border rounded-sm bg-card p-4 hover:border-primary/50 transition-colors no-underline cursor-pointer block">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-foreground">${post.title}</p>
                <p class="text-xs text-muted-foreground mt-1 leading-relaxed line-clamp-2">${post.brief}</p>
              </div>
              <div class="flex flex-col items-end gap-1 flex-shrink-0">
                <span class="text-xs text-muted-foreground">${date}</span>
                <span class="text-[10px] text-muted-foreground">${post.readTimeInMinutes} min</span>
              </div>
            </div>
            ${tags.length > 0 ? `
              <div class="flex flex-wrap gap-1.5 mt-2">
                ${tags.map((t) => `<span class="text-xs text-muted-foreground bg-muted/50 border border-border rounded-sm px-1.5 py-0.5">${t}</span>`).join("")}
              </div>
            ` : ""}
          </a>
        `;
      }).join("");
    } catch (_) {
      loading?.classList.add("hidden");
      error?.classList.remove("hidden");
    }
  }

  loadBlog();
</script>
