---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
import { projects } from "@/data/projects";
import { journey } from "@/data/journey";
import { fetchHashnodePosts } from "@/lib/hashnode";
import { badgeStyle } from "@/data/colors";

const latestProjects = projects.slice(0, 2);
const experience = journey.filter((e) => e.kind === "internship");
const education = journey.find((e) => e.kind === "education");
const latestPosts = fetchHashnodePosts().slice(0, 2);
---

<Layout title="Saikat Das - Backend Engineer" description="Backend engineer building fast, real-time systems in Go. IIT (BHU) Varanasi.">
  <Sidebar />

  <div class="flex-1 min-w-0 border border-border rounded-sm bg-card mt-4 lg:mt-0 lg:max-h-[calc(100vh-4rem)] lg:flex lg:flex-col lg:sticky lg:top-8 lg:self-start">
    <NavTabs />

    <div class="p-5 sm:p-6 lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
      <div class="tab-content-enter lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
        <div class="lg:flex-1 lg:overflow-y-auto lg:pr-2 flex flex-col gap-7">

          <section>
            <h2 class="text-xs font-semibold text-primary uppercase tracking-widest mb-3 flex items-center gap-2">
              <span>►</span> About me
            </h2>
            <div>
              <p class="text-base text-muted-foreground leading-relaxed">
                I build backend systems that stay fast under pressure. Most of my time goes into Go, real-time architectures, and databases. The rest goes into chess, sketching, strong coffee, and traveling to find great food.
              </p>
            </div>
          </section>

          {experience.length > 0 && (
            <section>
              <h2 class="text-xs font-semibold text-primary uppercase tracking-widest mb-3 flex items-center gap-2">
                <span>◆</span> Experience
              </h2>
              <div class="flex flex-col gap-2">
                {experience.map((entry) => (
                  <a
                    href="/journey"
                    class="rounded-sm bg-muted/20 p-3 flex items-start justify-between gap-3 hover:bg-muted/50 transition-colors no-underline cursor-pointer"
                  >
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-foreground leading-snug">{entry.title}</p>
                      <p class="text-xs text-muted-foreground mt-0.5">{entry.org} · {entry.period}</p>
                      {entry.bullets && entry.bullets.length > 0 ? (
                        <ul class="mt-1.5 flex flex-col gap-1">
                          {entry.bullets.map((point) => (
                            <li class="text-xs text-muted-foreground flex items-start gap-1.5">
                              <span class="text-primary text-[8px] mt-[3px] flex-shrink-0">▸</span>
                              <span>{point}</span>
                            </li>
                          ))}
                        </ul>
                      ) : entry.description && (
                        <p class="text-xs text-muted-foreground mt-1.5">{entry.description}</p>
                      )}
                    </div>
                    {entry.highlight && (
                      <span
                        class="hidden sm:inline-block text-[11px] border rounded-sm px-1.5 py-0.5 flex-shrink-0 font-medium"
                        style={badgeStyle(entry.kind)}
                      >
                        {entry.highlight}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </section>
          )}

          {education && (
            <section>
              <h2 class="text-xs font-semibold text-primary uppercase tracking-widest mb-3 flex items-center gap-2">
                <span>◎</span> Education
              </h2>
              <a
                href="/journey"
                class="rounded-sm bg-muted/20 p-3 flex items-start justify-between gap-3 hover:bg-muted/50 transition-colors no-underline cursor-pointer"
              >
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-foreground leading-snug">{education.title}</p>
                  <p class="text-xs text-muted-foreground mt-0.5">{education.org} · {education.period}</p>
                </div>
                <span
                  class="hidden sm:inline-block text-[11px] border rounded-sm px-1.5 py-0.5 flex-shrink-0 font-medium"
                  style={badgeStyle("education")}
                >
                  Education
                </span>
              </a>
            </section>
          )}

          {latestProjects.length > 0 && (
            <section>
              <h2 class="text-xs font-semibold text-primary uppercase tracking-widest mb-3 flex items-center gap-2">
                <span>□</span> Latest Projects
              </h2>
              <div class="flex flex-col gap-2">
                {latestProjects.map((project) => (
                  <a
                    href="/projects"
                    class="rounded-sm bg-muted/20 p-3 flex items-start justify-between gap-3 hover:bg-muted/50 transition-colors no-underline cursor-pointer"
                  >
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-foreground">{project.title}</p>
                      <p class="text-xs text-muted-foreground mt-0.5 line-clamp-1">{project.description}</p>
                    </div>
                    <span class="hidden sm:inline-block text-xs text-muted-foreground flex-shrink-0">
                      {new Date(project.date).toLocaleDateString("en-US", { month: "short", year: "numeric" })}
                    </span>
                  </a>
                ))}
              </div>
            </section>
          )}

          {latestPosts.length > 0 && (
            <section>
              <h2 class="text-xs font-semibold text-primary uppercase tracking-widest mb-3 flex items-center gap-2">
                <span>≡</span> Latest Posts
              </h2>
              <div class="flex flex-col gap-2">
                {latestPosts.map((post) => {
                  const date = new Date(post.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
                  return (
                    <a
                      href={post.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="rounded-sm bg-muted/20 p-3 flex items-start justify-between gap-3 hover:bg-muted/50 transition-colors no-underline cursor-pointer"
                    >
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-foreground">{post.title}</p>
                        <p class="text-xs text-muted-foreground mt-0.5 line-clamp-1">{post.brief}</p>
                      </div>
                      <div class="hidden sm:flex flex-col items-end gap-0.5 flex-shrink-0">
                        <span class="text-xs text-muted-foreground">{date}</span>
                        <span class="text-[11px] text-muted-foreground">{post.readTimeInMinutes}m read</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </section>
          )}

        </div>
      </div>
    </div>
  </div>
</Layout>
