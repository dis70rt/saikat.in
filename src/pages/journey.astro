---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";
import NavTabs from "@/components/NavTabs.astro";
import TimelineEntry from "@/components/TimelineEntry.astro";
import { journey, type JourneyKind } from "@/data/journey";
import { kindColors } from "@/data/colors";

const kindLabels: Record<JourneyKind, string> = {
  education: "Education",
  internship: "Internship",
  hackathon: "Hackathon",
  achievement: "Achievement",
  leadership: "Leadership",
};

const activeKinds = [...new Set(journey.map((e) => e.kind))];
---

<Layout title="Journey - Saikat Das" description="Education, hackathons, internships, and achievements timeline.">
  <Sidebar />

  <div class="flex-1 min-w-0 nb-card overflow-hidden mt-4 lg:mt-0 lg:max-h-[calc(100vh-4rem)] lg:flex lg:flex-col lg:sticky lg:top-8 lg:self-start">
    <NavTabs />

    <div class="p-5 sm:p-6 lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
      <div class="tab-content-enter lg:flex-1 lg:min-h-0 lg:flex lg:flex-col">
        <div class="flex flex-wrap gap-x-4 gap-y-1.5 mb-6">
          {activeKinds.map((kind) => (
            <span class="flex items-center gap-1.5 text-xs text-muted-foreground font-bold uppercase tracking-wider">
              <span class="w-2 h-2" style={`background:${kindColors[kind].hex}; box-shadow: 1px 1px 0 0 #000;`} />
              {kindLabels[kind]}
            </span>
          ))}
        </div>

        <div class="relative lg:flex-1 lg:overflow-y-auto lg:pr-2">
          <div class="flex flex-col gap-0">
            {journey.map((entry, idx) => (
              <TimelineEntry entry={entry} isLast={idx === journey.length - 1} />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
